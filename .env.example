# LLM provider API keys. The eval harness supplies these at runtime.
# The v0 baseline (main) needs NEITHER; the exploration branches use both.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional bearer token. If set, all endpoints except /health require:
#   Authorization: Bearer <token>
MEMORY_AUTH_TOKEN=

# Pipeline selection (defaults shown). Branches may add "llm".
MEMORY_EXTRACTOR=baseline
MEMORY_RECALLER=baseline
