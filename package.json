{
  "name": "memory-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check:reqs": "tsx scripts/check-requirements.ts",
    "bench": "tsx bench/harness.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.24",
    "@electric-sql/pglite": "^0.2.17",
    "@hono/node-server": "^1.13.7",
    "ai": "^4.3.19",
    "hono": "^4.6.14",
    "tsx": "^4.22.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
