# mem0 + FAISS baseline. Needs both keys (mem0 LLM = Anthropic, embeddings = OpenAI).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Same model our builds default to, for an apples-to-apples LoCoMo comparison.
MEMORY_LLM_MODEL=claude-haiku-4-5-20251001
MEMORY_EMBED_MODEL=text-embedding-3-large
MEMORY_EMBED_DIM=3072
MEMORY_DATA_DIR=/data/faiss
PORT=8080
