{
  "name": "memory-service-simple",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "The 'simple' memory service: minimal moving parts, readable and inspectable.",
  "engines": { "node": ">=22" },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@electric-sql/pglite": "0.2.17",
    "@hono/node-server": "^1.13.7",
    "ai": "^6.0.0",
    "hono": "^4.6.14",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
