# --- The "simple" memory service: environment ---
# The service runs fully OFFLINE with a deterministic mock provider when no keys
# are present (handy for CI and local hacking). Supply real keys to enable the
# LLM extraction pass and OpenAI embeddings.

# OpenAI: used for text-embedding-3-large (3072-dim) semantic search.
OPENAI_API_KEY=

# Anthropic: used for claude-opus-4-8 structured extraction + optional compaction.
ANTHROPIC_API_KEY=

# Optional bearer token. If set, every endpoint except /health requires
# `Authorization: Bearer <token>`. Leave empty to disable auth.
MEMORY_AUTH_TOKEN=

# Where pglite persists its data (a directory, mounted on a Docker volume).
MEMORY_DATA_DIR=/data/pgdata

# HTTP port. Container default is 8080; this variant benches on 8092 locally.
PORT=8080

# Force the offline mock provider even when keys are present (deterministic tests).
# MEMORY_PROVIDER=mock

# Disable the optional LLM compaction step in /recall (pure deterministic assembly).
# MEMORY_COMPACTION=off
