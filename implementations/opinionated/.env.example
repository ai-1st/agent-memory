# --- LLM / embedding provider keys ---
# This service is LLM-first: extraction, reconciliation, and recall all call
# the LLM via the Vercel AI SDK. Both keys are required for live operation.
#   Embeddings: OpenAI text-embedding-3-large (3072-dim)
#   LLM:        Anthropic Claude (model below)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Chat model. Default Haiku 4.5 — measured 76% on LoCoMo (hardest benchmark) with
# the full pipeline, ~1/15 Opus cost, and inside the 60s /turns budget even with
# chunked extraction. Use claude-opus-4-8 for maximum quality (slower, pricier).
MEMORY_LLM_MODEL=claude-haiku-4-5-20251001

# Chunked extraction: on dense (8+ message) turns, extract from each focused
# message-window AND the whole turn, then semantic-dedup. The biggest recall
# lever (LoCoMo 57→67). On by default; set 0 to disable.
MEMORY_CHUNK_EXTRACT=1

# Multi-query retrieval (experimental): generate follow-up queries from first-round
# facts and merge. Measured NOT to help on LoCoMo (wider recall already covers it).
# Off by default.
MEMORY_MULTI_QUERY=0

# Optional bearer token. If set, all endpoints except /health require:
#   Authorization: Bearer <token>
MEMORY_AUTH_TOKEN=

# Where pglite persists its data directory (mounted on the Docker volume).
MEMORY_DATA_DIR=/data/pg

# HTTP port. Container default is 8080; for local/parallel dev use 8091.
PORT=8080

# LLM provider seam. "live" calls real models; "mock" is deterministic/offline
# (used by the test suite). Defaults to "live" unless overridden.
MEMORY_LLM=live
