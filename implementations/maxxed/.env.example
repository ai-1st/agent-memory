# --- maxxed memory service configuration ---

# Where pglite persists its data directory (mounted on a Docker volume).
MEMORY_DB_DIR=/data/pgdata

# Optional bearer token. If set, all endpoints except /health require
# `Authorization: Bearer <token>`. If unset, auth is ignored (per contract).
MEMORY_AUTH_TOKEN=

# Pipeline selection. "llm" enables the full extract->reconcile + hybrid recall
# pipelines (requires API keys). "rule" / "mock" run fully offline (no network),
# which is what the contract test-suite uses.
#   MEMORY_PIPELINE = llm | rule
MEMORY_PIPELINE=llm

# Models (Vercel AI SDK). Defaults match the shared stack.
MEMORY_LLM_MODEL=claude-opus-4-8
MEMORY_EMBED_MODEL=text-embedding-3-large
MEMORY_EMBED_DIM=3072

# API keys — required only when MEMORY_PIPELINE=llm.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# HTTP port. Container default 8080; the maxxed dev/bench port is 8093.
PORT=8080
